# Backend environment variables
# Copy to: backend/.env (or project-root .env)

# Core
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<db>?retryWrites=true&w=majority
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
PASSWORD_SALT_ROUNDS=10

# Mongo connection tuning (optional)
MONGO_CONNECT_MAX_RETRIES=5
MONGO_CONNECT_RETRY_DELAY_MS=3000
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_SOCKET_TIMEOUT_MS=45000
MONGO_HEARTBEAT_FREQUENCY_MS=10000
MONGO_MAX_POOL_SIZE=20
MONGO_MIN_POOL_SIZE=2

# Twilio Voice
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VOICE_FROM=+1XXXXXXXXXX
TWILIO_HINDI_VOICE=Polly.Aditi
TWILIO_HINDI_LANGUAGE=hi-IN
TWILIO_ALLOW_TRIAL_FALLBACK=true

# Public backend URL for Twilio webhooks
# Use PUBLIC_BASE_URL. BACKEND_PUBLIC_URL and TWILIO_WEBHOOK_BASE_URL are fallbacks.
PUBLIC_BASE_URL=https://your-public-backend-url
BACKEND_PUBLIC_URL=
TWILIO_WEBHOOK_BASE_URL=

# Twilio speech behavior (optional)
TWILIO_SPEECH_MODEL=experimental_conversations
TWILIO_SPEECH_LANGUAGE=hi-IN
TWILIO_SPEECH_TIMEOUT_SECONDS=2
TWILIO_MIN_SPEECH_CONFIDENCE=0.30
TWILIO_ACTION_ON_EMPTY_RESULT=true
TWILIO_PROFANITY_FILTER=false
TWILIO_SPEECH_HINTS=haan,nahin,theek,dawai,dard,saans,chakkar,bukhar,tension,udaas

# LLM provider
LLM_PROVIDER=groq

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_ENABLED=true
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_RETRIES=2
GROQ_RETRY_BASE_DELAY_MS=700
GROQ_MIN_REQUEST_GAP_MS=3000
GROQ_COOLDOWN_MS=600000
GROQ_QUOTA_ZERO_COOLDOWN_MS=21600000
GROQ_DISABLE_ON_QUOTA_ZERO=true

# Gemini (optional / fallback)
GEMINI_ENABLED=false
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite,gemini-2.5-flash
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_DELAY_MS=700

# Prompt manager (optional)
PROMPT_STATE_MAX_CHARS=4000

# ElevenLabs (optional)
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=hindi_warm_female
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32
ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=1
ELEVENLABS_LANGUAGE_CODE=hi
ELEVENLABS_TEXT_NORMALIZATION=auto
ELEVENLABS_TIMEOUT_MS=9000
ELEVENLABS_COOLDOWN_MS=3600000
ELEVENLABS_VOICE_STABILITY=0.35
ELEVENLABS_VOICE_SIMILARITY=0.82
ELEVENLABS_VOICE_STYLE=0.45
ELEVENLABS_VOICE_SPEED=0.93
ELEVENLABS_VOICE_USE_SPEAKER_BOOST=true
ELEVENLABS_CLONE_STABILITY=0.42
ELEVENLABS_CLONE_SIMILARITY=0.90
ELEVENLABS_CLONE_STYLE=0.55
ELEVENLABS_CLONE_SPEED=0.92

# Voice runtime guards
TTS_GENERATION_TIMEOUT_MS=3500
AI_REPLY_TIMEOUT_MS=5500
AI_REPLY_TIMEOUT_MAX_MS=7000
MAX_CALL_TURNS=6

# WhatsApp alerts (optional)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Scheduler logging (optional)
SCHEDULER_VERBOSE_LOGS=true

# ArmorIQ service (optional)
ARMORIQ_API_KEY=
