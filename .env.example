# Backend (.env)

# Core
PORT=5000
MONGODB_URI=mongodb+srv://...

# Twilio Voice (required for calls)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_VOICE_FROM=+1XXXXXXXXXX
TWILIO_HINDI_VOICE=Polly.Aditi
TWILIO_HINDI_LANGUAGE=hi-IN
PUBLIC_BASE_URL=https://your-public-backend-url
TWILIO_ALLOW_TRIAL_FALLBACK=true

# Groq Llama (required for call summary + memory extraction)
GROQ_API_KEY=
GROQ_ENABLED=true
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_RETRIES=2
GROQ_RETRY_BASE_DELAY_MS=700
GROQ_MIN_REQUEST_GAP_MS=3000
GROQ_COOLDOWN_MS=600000
GROQ_QUOTA_ZERO_COOLDOWN_MS=21600000
GROQ_DISABLE_ON_QUOTA_ZERO=true

# Legacy Gemini flags (keep disabled)
GEMINI_ENABLED=false

# ElevenLabs (optional for future TTS extensions)
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=hindi_warm_female
TTS_GENERATION_TIMEOUT_MS=3500
AI_REPLY_TIMEOUT_MS=2500
MAX_CALL_TURNS=6

# Twilio (optional; required only for WhatsApp alerts)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App
FRONTEND_URL=http://localhost:3000

# Frontend (frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:5000
